# ── PEERACE PORTFOLIO — Environment Variables ──
# Copy this file to .env and fill in your values

# Server
PORT=3000
SITE_URL=https://your-username.github.io

# Gmail credentials (use App Password, NOT your regular Gmail password)
# To get App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Admin key for viewing subscriber list
ADMIN_KEY=change-this-to-something-secret-123
